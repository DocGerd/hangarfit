# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.cache/
nosetests.xml
coverage.xml

# Type checkers
.mypy_cache/
.pyre/
.ruff_cache/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Project artifacts
out*.png
*.local.*

# Explicit even though *.local.* already matches — keeps the intent
# visible to contributors grepping for ".claude" (issue #35).
.claude/settings.local.json
